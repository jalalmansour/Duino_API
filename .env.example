# ─── Duino API — Environment Configuration ───────────────────────────────────
# Copy to .env and fill in values. Never commit .env to version control.

# ── Server ──────────────────────────────────────────────────────────────────
DUINO_HOST=0.0.0.0
DUINO_PORT=8000
DUINO_ENV=development          # development | production
DUINO_SECRET_KEY=change-me-in-production-use-secrets-generate

# ── Model ───────────────────────────────────────────────────────────────────
DEFAULT_MODEL=gemma-4-2b
HF_TOKEN=hf_your_huggingface_token_here
HF_HOME=/tmp/hf_cache

# ── Redis (Session Store) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
SESSION_TTL_SECONDS=86400      # 24 hours

# ── Tunneling ───────────────────────────────────────────────────────────────
NGROK_AUTHTOKEN=your_ngrok_token_here
CF_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ── Quota Defaults ──────────────────────────────────────────────────────────
QUOTA_FREE_RPM=10
QUOTA_FREE_DAILY=500
QUOTA_PRO_RPM=60
QUOTA_PRO_DAILY=10000
QUOTA_ENT_RPM=300
QUOTA_ENT_DAILY=100000

# ── Observability ───────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── UI ──────────────────────────────────────────────────────────────────────
UI_PORT=3000
UI_BUILD_DIR=ui/dist
